[Unit]
Description=Torch Proxy FastAPI Service
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/torch-proxy
Environment="PATH=/opt/torch-proxy/.venv/bin"
ExecStart=/opt/torch-proxy/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
